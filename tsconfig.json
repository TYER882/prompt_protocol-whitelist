{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "noImplicitAny": false,
    "types": ["node", "express"],

    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src", "server", "api"],
  "exclude": ["node_modules"]
}